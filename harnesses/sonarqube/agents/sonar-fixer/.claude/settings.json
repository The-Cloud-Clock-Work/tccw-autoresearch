{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://10.10.30.130:4317",
    "OTEL_RESOURCE_ATTRIBUTES": "project.name=antoncore,agent.name=sonar-fixer,environment=autoresearch",
    "OTEL_LANGFUSE_ENABLED": "1",
    "OTEL_LANGFUSE_ENDPOINT": "https://langfuse.homeofanton.com/api/public/otel"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(ruff *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git reset --hard *)",
      "Bash(pip install *)",
      "Bash(npm install *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
