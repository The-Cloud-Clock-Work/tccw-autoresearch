# AutoResearch Agent Environment Variables
# Copy this file to .env and fill in your values.
# These variables are loaded before the agent runs.

# MCP server credentials
# MCP_API_KEY=

# OTEL telemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_RESOURCE_ATTRIBUTES=agent.name=default,environment=dev

# Custom hooks
# AUTORESEARCH_HOOK_URL=

# API keys for external tools
# GITHUB_TOKEN=
# JIRA_TOKEN=
